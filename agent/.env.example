# Mistral API key (required) — STT + LLM + TTS
MISTRAL_API_KEY=your_mistral_api_key_here

# Linkup API key (required for live reimbursement search, falls back to hardcoded data)
LINKUP_API_KEY=your_linkup_api_key_here

# Thryve API key (optional — falls back to hardcoded wearable data)
THRYVE_API_KEY=your_thryve_api_key_here
THRYVE_APP_ID=your_thryve_app_id_here

# LiveKit credentials (auto-injected by LiveKit Cloud, only needed for local dev)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
